@{
    ViewData["Title"] = "MoviePicker";
}

<div class="main-hero text-center py-5">
    <h1 class="brand-title"><span style="color: var(--text-white)">MOVIE</span><span style="color: var(--flag-red)">PICKER</span></h1>
    <p class="text-muted">Find a perfect movie alone or with your party.</p>
</div>

<div class="landing-wrapper">
    <div class="options-container">
        <a href="@Url.Action("Solo", "Movie")" class="choice-card solo">
            <h2>Swipe Solo</h2>
            <p>Find a movie for yourself</p>
        </a>

        <a href="@Url.Action("SetupParty", "Room")" class="choice-card party">
            <h2>Movie Party</h2>
            <p>Decide with friends</p>
        </a>
    </div>
</div>


<style>
    .landing-wrapper {
        text-align: center;
        padding-top: 5vh;
    }

    .options-container {
        display: flex;
        gap: 2rem;
        justify-content: center;
        margin-top: 0rem;
    }

    .choice-card {
        background: #0b1e2b;
        border: 2px solid var(--khaki-beige);
        padding: 3rem;
        border-radius: 20px;
        width: 320px;
        height: 320px;
        text-decoration: none;
        color: var(--porcelain);
        transition: 0.3s ease;

        display: flex;
        flex-direction: column;
        justify-content: center; /* Vertikalno centriranje */
        align-items: center; /* Horizontalno centriranje */
        text-align: center;
    }

        .choice-card:hover {
            border-color: var(--flag-red);
            color: var(--khaki-beige);
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

    .brand-title {
        font-size: 4rem;
        color: var(--flag-red);
        font-weight: 900;
    }
</style>