@model MoviePicker.Models.Entities.Room

<link rel="stylesheet" href="~/css/swipe.css" />

<div class="swipe-page">
    <div id="swipe-container">
        <h2>Swipe through movies</h2>
        <div id="card-stack"></div>
        <div class="swipe-buttons">
            <button id="dislike-btn">✕ Dislike</button>
            <button id="like-btn">♥ Like</button>
        </div>
    </div>
    <div id="waiting-container" style="display:none">
        <h2>Waiting for others to finish...</h2>
    </div>
    <div id="results-container" style="display:none">
        <h2>Movies everyone liked</h2>
        <div id="results-list"></div>
        <br />
        <a href="/Movie/Index">Search Again</a>
    </div>

    <div id="modal-overlay" style="display:none">
        <div id="modal-box">
            <button id="modal-close">✕</button>
            <div id="modal-content"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const movies = @Html.Raw(Json.Serialize(ViewBag.Movies));
        console.log("Movies count:", movies.length);//za testiranje
        const roomCode = "@Model.Code";
        const memberId = @Html.Raw(Json.Serialize(ViewBag.MemberId));

        let currentIndex = 0;
        let likedMovies = [];
        let dislikedMovies = [];

        const cardStack = document.getElementById('card-stack');
        const likeBtn = document.getElementById('like-btn');
        const dislikeBtn = document.getElementById('dislike-btn');
        const swipeContainer = document.getElementById('swipe-container');
        const resultsContainer = document.getElementById('results-container');
        const resultsList = document.getElementById('results-list');
        const modalOverlay = document.getElementById('modal-overlay');
        const modalClose = document.getElementById('modal-close');

        function createCard(movie) {
            const card = document.createElement('div');
            card.className = 'movie-card';
            card.innerHTML = `
                <img src="${movie.fullPosterUrl}" alt="${movie.title}" />
                <div class="card-info">
                    <h3>${movie.title}</h3>
                    <p>⭐ ${movie.vote_average.toFixed(1)} &nbsp; 📅 ${movie.release_date?.substring(0, 4)}</p>
                    <button class="see-more-btn" data-movie='${JSON.stringify(movie)}'>See More</button>
                </div>
            `;
            return card;
        }

        function showCurrentCard() {
            if (currentIndex >= movies.length) {
                finishSwiping();
                return;
            }
            cardStack.innerHTML = '';
            cardStack.appendChild(createCard(movies[currentIndex]));
        }

        async function swipe(liked) {
            if (currentIndex >= movies.length) return;

            const movie = movies[currentIndex];

            // Save swipe to database
            await fetch('/Room/RecordSwipe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    memberId: memberId,
                    movieId: movie.id,
                    liked: liked
                })
            });

            if (liked) likedMovies.push(movie);
            else dislikedMovies.push(movie);

            currentIndex++;
            showCurrentCard();
        }

        async function finishSwiping() {
            // Tell server this member finished
            console.log("finishSwiping called for memberId:", memberId);
            await fetch('/Room/FinishSwiping', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ memberId: memberId, roomCode: roomCode })
            });
            swipeContainer.style.display = 'none';
            document.getElementById('waiting-container').style.display = 'block';
        }

        // SignalR for real-time results
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/roomHub")
            .build();

        connection.on("ShowResults", function(likedMovieIds) {
            swipeContainer.style.display = 'none';
            resultsContainer.style.display = 'block';

            const matchedMovies = movies.filter(m => likedMovieIds.includes(m.id));

            if (matchedMovies.length === 0) {
                resultsList.innerHTML = '<p>No movies matched. Try again!</p>';
                return;
            }

            matchedMovies.forEach(movie => {
                const card = createCard(movie);
                card.className = 'result-card';
                resultsList.appendChild(card);
            });
        });

        connection.start()
            .then(() => connection.invoke("JoinRoomGroup", roomCode))
            .catch(err => console.error(err));

        // Modal
        document.addEventListener('click', function(event) {
            if (event.target.closest('.see-more-btn')) {
                const btn = event.target.closest('.see-more-btn');
                const movie = JSON.parse(btn.dataset.movie);
                document.getElementById('modal-content').innerHTML = `
                    <div class="modal-poster">
                        <img src="${movie.fullPosterUrl}" alt="${movie.title}" />
                    </div>
                    <div class="modal-details">
                        <h2>${movie.title}</h2>
                        <div class="modal-meta">
                            <span class="modal-rating">⭐ ${movie.vote_average.toFixed(1)}</span>
                            <span class="modal-year">📅 ${movie.release_date?.substring(0, 4)}</span>
                        </div>
                        <p class="modal-overview">${movie.overview}</p>
                    </div>
                `;
                modalOverlay.style.display = 'flex';
            }
        });

        modalClose.addEventListener('click', () => modalOverlay.style.display = 'none');
        modalOverlay.addEventListener('click', e => { if (e.target === modalOverlay) modalOverlay.style.display = 'none'; });

        likeBtn.addEventListener('click', () => swipe(true));
        dislikeBtn.addEventListener('click', () => swipe(false));

        showCurrentCard();
    </script>
}