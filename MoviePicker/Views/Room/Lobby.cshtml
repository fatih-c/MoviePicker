@model MoviePicker.Models.Entities.Room

<div class="room-page">
    <h2>Room Code: <strong>@Model.Code</strong></h2>
    <p>Share this code with your friends</p>

    <h3>Members</h3>
    <ul id="members-list">
        @foreach (var member in Model.Members)
        {
            <li>@member.Name @(member.IsCreator ? "(Creator)" : "")</li>
        }
    </ul>

    @if (ViewBag.IsCreator)
    {
        <div class="solo-container">
            <div class="text-center mb-4">
                <h3 class="fw-bold" style="color: var(--flag-red);">ROOM SETTINGS</h3>
                <p style="color: var(--khaki-beige);">Set filters for all room members.</p>
            </div>

            <div class="filter-card p-4 p-md-5">
                <form asp-action="Start" asp-controller="Room" method="post">
                    <input type="hidden" name="code" value="@Model.Code" />
                    @await Html.PartialAsync("_FilterForm", new MoviePicker.Models.MovieFilterViewModel())

                    <div class="d-grid gap-3 mt-5">
                        <button type="submit" class="btn-outline">
                            Start Swiping Mode
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <p id="waiting-msg">Waiting for creator to start...</p>
    }
</div>

@section Scripts {
    <script>
        const roomCode = "@Model.Code";
        const isCreator = @Json.Serialize((bool)ViewBag.IsCreator);

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/roomHub")
            .build();

        connection.on("MemberJoined", function(memberName) {
            const li = document.createElement("li");
            li.textContent = memberName;
            document.getElementById("members-list").appendChild(li);
        });

        connection.on("GameStarted", function(code) {
            window.location.href = "/Room/Swipe?code=" + code;
        });

        connection.start()
            .then(function() {
                console.log("SignalR connected!");
                return connection.invoke("JoinRoomGroup", roomCode);
            })
            .then(function() {
                console.log("Joined room group: " + roomCode);
            })
            .catch(function(err) {
                console.error("SignalR error: ", err);
            });
    </script>
}

<style>
    :root {
        --bg-color: #1a222d;
        --card-bg: #252f3d;
        --flag-red: #C50720;
        --khaki-beige: #BEB7A4;
    }

    .solo-container {
        max-width: 800px;
        margin: 40px auto;
    }

    .filter-card {
        background-color: var(--card-bg);
        border-radius: 20px;
        border: 1px solid rgba(190, 183, 164, 0.1);
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
    }

    .btn-main {
        background-color: var(--flag-red);
        color: white;
        border: none;
        padding: 15px;
        border-radius: 12px;
        font-weight: bold;
        font-size: 1.1rem;
        transition: 0.3s;
    }

        .btn-main:hover {
            transform: scale(1.02);
            filter: brightness(1.2);
        }

    .btn-outline {
        background-color: transparent;
        border: 2px solid var(--khaki-beige);
        color: var(--khaki-beige);
        padding: 15px;
        border-radius: 12px;
        font-weight: bold;
        font-size: 1.1rem;
        transition: 0.3s;
    }

        .btn-outline:hover {
            background-color: var(--khaki-beige);
            color: var(--bg-color);
        }
</style>