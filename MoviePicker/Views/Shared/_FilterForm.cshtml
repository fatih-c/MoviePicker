@model MoviePicker.Models.MovieFilterViewModel

<div class="filter-grid">
    <div class="genre-section">
        <label class="section-title">Select Genres</label>
        <div class="chips-container">
            @{
                var genreMap = new Dictionary<string, string> {
                        {"28", "Action"},
                        {"12", "Adventure"},
                        {"16", "Animation"},
                        {"35", "Comedy"},
                        {"80", "Crime"},
                        {"99", "Documentary"},
                        {"18", "Drama"},
                        {"10751", "Family"},
                        {"14", "Fantasy"},
                        {"36", "History"},
                        {"27", "Horror"},
                        {"10402", "Music"},
                        {"9648", "Mystery"},
                        {"10749", "Romance"},
                        {"878", "Sci-Fi"},
                        {"53", "Thriller"},
                        {"10752", "War"},
                        {"37", "Western"}
                        };
            }
            @foreach (var genre in genreMap)
            {
                <label class="genre-chip">
                    <input type="checkbox" name="SelectedGenres" value="@genre.Key"
                           checked="@(Model.SelectedGenres.Contains(genre.Key))" />
                    <span>@genre.Value</span>
                </label>
            }
        </div>
    </div>

    <div class="select-section">
        <div class="input-group">
            <label>Minimum Rating</label>
            <select name="MinRating" class="custom-select">
                <option value="0">Any Rating</option>
                <option value="7">⭐ 7.0+</option>
                <option value="8">⭐ 8.0+</option>
            </select>
        </div>
        <div class="input-group">
            <label>Sort By</label>
            <select name="SortBy" class="custom-select">
                <option value="popularity.desc">Popularity</option>
                <option value="vote_average.desc">Top Rated</option>
            </select>
        </div>
    </div>
</div>

<style>
    .chips-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 15px 0;
        justify-content: center;
    }

    .genre-chip input {
        display: none;
    }

    .genre-chip span {
        display: inline-block;
        padding: 8px 20px;
        border: 1px solid var(--khaki-beige);
        border-radius: 20px;
        cursor: pointer;
        transition: 0.3s;
        background: transparent;
        color: var(--khaki-beige);
    }

    .genre-chip input:checked + span {
        background: var(--flag-red);
        border-color: var(--flag-red);
        color: white;
    }

    .custom-select {
        background: #1a1a1a;
        color: white;
        border: 1px solid var(--khaki-beige);
        padding: 10px;
        border-radius: 8px;
        width: 100%;
    }

    .section-title {
        font-weight: bold;
        color: var(--porcelain);
        margin-bottom: 10px;
        display: block;
    }
</style>