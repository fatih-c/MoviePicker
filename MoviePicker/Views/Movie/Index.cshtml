@model MoviePicker.Models.MovieFilterViewModel

@{
    ViewData["Title"] = "Movie Picker";
}

<h2>Movie Picker</h2>

<form method="post" action="/Movie/Index">
    @await Html.PartialAsync("_FilterForm", Model)
    <br /><br />
    <button type="submit">Find Movies</button>
    <button type="submit" asp-action="Swipe" asp-controller="Movie">Swipe Movies</button>
</form>

@if (Model.Movies.Any())
{
    <h3>Results</h3>
    <div style="display:flex; flex-wrap:wrap; gap:16px;">
        @foreach (var movie in Model.Movies)
        {
            <div style="width:180px; border:1px solid #ccc; padding:8px; border-radius:8px;">
                <img src="@movie.FullPosterUrl" style="width:100%;" alt="@movie.Title" />
                <h4>@movie.Title</h4>
                <p>⭐ @movie.VoteAverage</p>
                <p style="font-size:11px; color:gray;">@movie.ReleaseDate</p>
            </div>
        }
    </div>
}