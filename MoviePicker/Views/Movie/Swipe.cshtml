@model MoviePicker.Models.MovieFilterViewModel

<link rel="stylesheet" href="~/css/swipe.css" />

<div class="swipe-page">

    <div id="swipe-container">
        <h2>Swipe through movies</h2>

        <div id="card-stack"></div>

        <div class="swipe-buttons">
            <button id="dislike-btn">✕ Dislike</button>
            <button id="like-btn">♥ Like</button>
        </div>
    </div>

    <div id="results-container" style="display:none">
        <h2>Movies you liked</h2>
        <div id="results-list"></div>
        <br />
        <a href="/Movie/Solo">Search Again</a>
    </div>

    <div id="modal-overlay" style="display:none">
        <div id="modal-box">
            <button id="modal-close">✕</button>
            <div id="modal-content"></div>
        </div>
    </div>

</div>

<script>
    const movies = @Html.Raw(Json.Serialize(Model.Movies));

    let currentIndex = 0;
    let likedMovies = [];
    let dislikedMovies = [];

    const cardStack = document.getElementById('card-stack');
    const likeBtn = document.getElementById('like-btn');
    const dislikeBtn = document.getElementById('dislike-btn');
    const swipeContainer = document.getElementById('swipe-container');
    const resultsContainer = document.getElementById('results-container');
    const resultsList = document.getElementById('results-list');
    const modalOverlay = document.getElementById('modal-overlay');
    const modalTitle = document.getElementById('modal-title');
    const modalOverview = document.getElementById('modal-overview');
    const modalClose = document.getElementById('modal-close');

    function createCard(movie) {
        const card = document.createElement('div');
        card.className = 'movie-card';
        card.innerHTML = `
            <img src="${movie.fullPosterUrl}" alt="${movie.title}" />
            <div class="card-info">
                <h3>${movie.title}</h3>
                <p>⭐ ${movie.vote_average.toFixed(1)} &nbsp; 📅 ${movie.release_date?.substring(0, 4)}</p>
                <button class="see-more-btn" data-movie='${JSON.stringify(movie)}'>See More</button>
            </div>
        `;
        return card;
    }

    function showCurrentCard() {
        if (currentIndex >= movies.length) {
            showResults();
            return;
        }
        cardStack.innerHTML = '';
        const card = createCard(movies[currentIndex]);
        cardStack.appendChild(card);
    }

    function swipe(liked) {
        if (currentIndex >= movies.length) return;
        if (liked) {
            likedMovies.push(movies[currentIndex]);
        } else {
            dislikedMovies.push(movies[currentIndex]);
        }
        currentIndex++;
        showCurrentCard();
    }

    function showResults() {
        swipeContainer.style.display = 'none';
        resultsContainer.style.display = 'block';

        if (likedMovies.length === 0) {
            resultsList.innerHTML = '<p>You did not like any movies. Try different filters!</p>';
            return;
        }

        likedMovies.forEach(movie => {
            const card = createCard(movie);
            card.className = 'result-card';
            resultsList.appendChild(card);
        });
    }

    likeBtn.addEventListener('click', () => swipe(true));
    dislikeBtn.addEventListener('click', () => swipe(false));

      document.addEventListener('click', function(event) {
        if (event.target.closest('.see-more-btn')) {
            const btn = event.target.closest('.see-more-btn');
            const movie = JSON.parse(btn.dataset.movie);

            document.getElementById('modal-content').innerHTML = `
                <div class="modal-poster">
                    <img src="${movie.fullPosterUrl}" alt="${movie.title}" />
                </div>
                <div class="modal-details">
                    <h2>${movie.title}</h2>
                    <div class="modal-meta">
                        <span class="modal-rating">⭐ ${movie.vote_average.toFixed(1)}</span>
                        <span class="modal-year">📅 ${movie.release_date?.substring(0, 4)}</span>
                    </div>
                    <p class="modal-overview">${movie.overview}</p>
                </div>
            `;

            modalOverlay.style.display = 'flex';
        }
    });

    modalClose.addEventListener('click', () => {
        modalOverlay.style.display = 'none';
    });

    modalOverlay.addEventListener('click', function(event) {
        if (event.target === modalOverlay) {
            modalOverlay.style.display = 'none';
        }
    });

    showCurrentCard();
</script>